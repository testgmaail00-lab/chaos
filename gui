	local isOpen = true
	local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
	
	local function toggleMenu()
		isOpen = not isOpen
	
		if isOpen then
			-- Menüyü yumuşakça gösteriyoruz
			mainFrame.Visible = true
			TweenService:Create(mainFrame, tweenInfo, {Size = UDim2.new(0, 569, 0, 483)}):Play() -- Boyutu kendi menü boyutuna göre ayarlayabilirsin
	
			-- Yandaki uyarı yazısını gizliyoruz
			hintLabel.Visible = false
		else
			-- Menüyü kapatıyoruz
			mainFrame.Visible = false
	
			-- Yandaki uyarı yazısını gösteriyoruz
			hintLabel.Visible = true
			-- Yazıya küçük bir animasyon (Belirme efekti)
			hintLabel.TextTransparency = 1
			TweenService:Create(hintLabel, tweenInfo, {TextTransparency = 0}):Play()
		end
