local function C_b()
local script = G2L["b"];
	local TweenService = game:GetService("TweenService")
	local UserInputService = game:GetService("UserInputService")
	local Players = game:GetService("Players")
	
	local background = script.Parent
	local circle = background:WaitForChild("squiddyAl")
	
	-- AÇILIP KAPANACAK MENÜYÜ BULMA
	-- 'ExternalsGui' adındaki arayüzünü PlayerGui içinde arıyoruz
	local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
	local externalsMenu = playerGui:FindFirstChild("ExternalsGui", true) -- "true" yaparak her yerde arar
	
	local isOn = false
	local isDragging = false
	
	-- RENKLER
	local offColor = Color3.fromRGB(0, 0, 0)
	local onColor = Color3.fromRGB(255, 0, 0)
	
	-- POZİSYONLAR
	local offPosition = UDim2.new(0.092, 0, 0.186, 0)
	local onPosition = UDim2.new(0.633, 0, 0.186, 0)
	
	local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
	
	-- Duruma göre pozisyona yumuşakça oturtma fonksiyonu
	local function snapToPosition(state)
		isOn = state
		local targetPosition = isOn and onPosition or offPosition
		local targetColor = isOn and onColor or offColor
	
		TweenService:Create(circle, tweenInfo, {
			Position = targetPosition,
			BackgroundColor3 = targetColor
		}):Play()
	
		-- --- ARAYÜZÜ GÖRÜNÜR / GÖRÜNMEZ YAPMA ---
		if externalsMenu then
			externalsMenu.Visible = isOn
		end
	
		-- Tetiklenecek fonksiyonlar
		if isOn then
			print("Özellik Açıldı!")
		else
			print("Özellik Kapandı!")
		end
	end
	
	-- Sürükleme başladığında
	circle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			isDragging = true
		end
	end)
	
	-- Mouse hareket ettikçe yuvarlağı takip ettirme
	UserInputService.InputChanged:Connect(function(input)
		if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			-- Arka planın genişliğini ve mouse'un o anki yerini hesaplıyoruz
			local bgX = background.AbsolutePosition.X
			local bgWidth = background.AbsoluteSize.X
			local mouseX = input.Position.X
	
			-- Yeni X pozisyonunu yüzdelik (Scale) olarak hesapla
			local newX = (mouseX - bgX) / bgWidth
	
			-- Yuvarlağın dışarı taşmasını engelle
			newX = math.clamp(newX, 0.092, 0.633)
	
			-- Yuvarlağın sadece X ekseninde hareket etmesini sağla
			circle.Position = UDim2.new(newX, 0, circle.Position.Y.Scale, 0)
		end
	end)
	
	-- Mouse bırakıldığında
	UserInputService.InputEnded:Connect(function(input)
		if isDragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
			isDragging = false
	
			-- Bırakıldığı yer butonun ortasından sağda mı solda mı?
			local currentX = circle.Position.X.Scale
			local midPoint = (0.092 + 0.633) / 2
	
			if currentX >= midPoint then
				snapToPosition(true)
			else
				snapToPosition(false)
			end
		end
	end)
	
	-- İlk başlangıçta kapalı başlasın
	snapToPosition(false)
end;
task.spawn(C_b);
