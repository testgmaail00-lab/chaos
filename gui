local isOpen = true
local function toggleMenu()
	isOpen = not isOpen
	if isOpen then
		G2L["2"].Visible = true
		if isExternalsOn() then G2L["2a"].Visible = true end
		if isTrollOn() then G2L["34"].Visible = true end
		if isSkinChangerOn() then G2L["3d"].Visible = true end
	else
		G2L["2"].Visible = false
		G2L["2a"].Visible = false
		G2L["34"].Visible = false
		G2L["3d"].Visible = false
	end
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.Delete then
		toggleMenu()
	end
end)


