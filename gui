-- 6. SÜRÜKLEMELİ BUTON KONTROLLERİ
-- ==========================================
local function setupToggle(background, circle, targetMenu)
	local isOn = false
	local isDragging = false

	local offColor = Color3.fromRGB(0, 0, 0)
	local onColor = Color3.fromRGB(255, 0, 0)

	local offPosition = UDim2.new(0.092, 0, 0.186, 0)
	local onPosition = UDim2.new(0.633, 0, 0.186, 0)

	local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)

	local function snapToPosition(state)
		isOn = state
		local targetPosition = isOn and onPosition or offPosition
		local targetColor = isOn and onColor or offColor

		TweenService:Create(circle, tweenInfo, {
			Position = targetPosition,
			BackgroundColor3 = targetColor
		}):Play()

		if targetMenu then targetMenu.Visible = isOn end
	end

	circle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			isDragging = true
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local bgX = background.AbsolutePosition.X
			local bgWidth = background.AbsoluteSize.X
			local mouseX = input.Position.X

			local newX = (mouseX - bgX) / bgWidth
			newX = math.clamp(newX, 0.092, 0.633)
			circle.Position = UDim2.new(newX, 0, circle.Position.Y.Scale, 0)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if isDragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
			isDragging = false
			local currentX = circle.Position.X.Scale
			local midPoint = (0.092 + 0.633) / 2

			if currentX >= midPoint then
				snapToPosition(true)
			else
				snapToPosition(false)
			end
		end
	end)

	snapToPosition(false)
	return function() return isOn end
end

